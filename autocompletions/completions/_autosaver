_autosaver__subcmd__help__subcmd__rmhome_commands() {
    local commands; commands=()
    _describe -t commands 'autosaver help rmhome commands' commands "$@"
}
(( $+functions[_autosaver__subcmd__help__subcmd__save_commands] )) ||
_autosaver__subcmd__help__subcmd__save_commands() {
    local commands; commands=()
    _describe -t commands 'autosaver help save commands' commands "$@"
}
(( $+functions[_autosaver__subcmd__list_commands] )) ||
_autosaver__subcmd__list_commands() {
    local commands; commands=()
    _describe -t commands 'autosaver list commands' commands "$@"
}
(( $+functions[_autosaver__subcmd__restore_commands] )) ||
_autosaver__subcmd__restore_commands() {
    local commands; commands=()
    _describe -t commands 'autosaver restore commands' commands "$@"
}
(( $+functions[_autosaver__subcmd__rmbackup_commands] )) ||
_autosaver__subcmd__rmbackup_commands() {
    local commands; commands=()
    _describe -t commands 'autosaver rmbackup commands' commands "$@"
}
(( $+functions[_autosaver__subcmd__rmhome_commands] )) ||
_autosaver__subcmd__rmhome_commands() {
    local commands; commands=()
    _describe -t commands 'autosaver rmhome commands' commands "$@"
}
